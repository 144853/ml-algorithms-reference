# Example: Deploy Linear Regression
# Copy this to terraform.tfvars and modify as needed.

algorithm_name = "linear_regression_sklearn"
environment    = "dev"
location       = "eastus"
vm_size        = "Standard_DS3_v2"
instance_count = 1

# For production:
# environment        = "prod"
# vm_size            = "Standard_DS4_v2"
# enable_autoscaling = true
# min_instances      = 2
# max_instances      = 8

# Other algorithms (just swap the name):
# algorithm_name = "random_forest_sklearn"
# algorithm_name = "gradient_boosting_sklearn"
# algorithm_name = "sentiment_analysis_sklearn"
